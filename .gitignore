# ============================================
# Dekorativ — .gitignore
# Stack: Next.js 14 · TypeScript · Tailwind v4
#        Firebase (Hosting + Cloud Functions)
# ============================================

# ── Dependencies ──────────────────────────────
node_modules/
functions/node_modules/
.pnp
.pnp.js
.yarn/

# ── Build / Output ───────────────────────────
.next/
out/
build/
dist/

# ── Environment Variables ────────────────────
.env
.env.*
!.env.local.example
functions/.env

# ── Firebase ─────────────────────────────────
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
database-debug.log
pubsub-debug.log
storage-debug.log

# ── Logs ─────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── IDE / Editor ─────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── OS Generated ─────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db
ehthumbs_vista.db

# ── TypeScript ───────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ── Testing / Coverage ──────────────────────
coverage/
.nyc_output/

# ── Temporary / Scratch Files ────────────────
temp_*.json
test-*.js
*.tmp
*.bak
*.cache

# ── Vercel ───────────────────────────────────
.vercel/

# ── Firebase Service Account Keys ────────────
*-firebase-adminsdk-*.json
